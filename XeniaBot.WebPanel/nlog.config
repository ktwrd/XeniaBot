<?xml version="1.0" encoding="utf-8" ?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      autoReload="true"
      throwConfigExceptions="true"
      internalLogLevel="Info"
      internalLogFile="internal-nlog-AspNetCore.log">

  <extensions>
    <add assembly="NLog.Web.AspNetCore"/>
  </extensions>

  <targets>
    <target xsi:type="File" name="allfile" fileName="nlog-AspNetCore-all-${shortdate}.log"
            layout="${longdate}|${event-properties:item=EventId:whenEmpty=0}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}" />
    <target xsi:type="File" name="ownFile-web" fileName="nlog-AspNetCore-own-${shortdate}.log"
            layout="${longdate}|${event-properties:item=EventId:whenEmpty=0}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}|url: ${aspnet-request-url}|action: ${aspnet-mvc-action}" />
    <target xsi:type="ColoredConsole" name="lifetimeConsole" layout="${MicrosoftConsoleLayout}" />
    <target xsi:type="File" name="aspnet-diagnostics" fileName="nlog-AspNetCore-Diagnostics-${shortdate}.log"
            layout="${longdate}|${event-properties:item=EventId:whenEmpty=0}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}|url: ${aspnet-request-url}|action: ${aspnet-mvc-action}" />
    <target xsi:type="File" name="efcore" fileName="nlog-EFCore-${shortdate}.log"
            layout="${longdate}|${event-properties:item=EventId:whenEmpty=0}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}" />
    <target xsi:type="File" name="efcore-diagnostics" fileName="nlog-EFCore-Diagnostics-${shortdate}.log"
            layout="${longdate}|${event-properties:item=EventId:whenEmpty=0}|${level:uppercase=true}|${logger}|${message} ${exception:format=tostring}" />
  </targets>

  <rules>
    <logger name="*" minlevel="Debug" writeTo="lifetimeConsole">
      <filters defaultAction="Neutral">
        <when condition="starts-with(logger, 'Microsoft.') and LogLevel.Debug >= level" action="Ignore" />
      </filters>
    </logger>
    <logger name="*" minlevel="Debug" writeTo="allfile" />

    <logger name="Microsoft.EntityFramework.*" minLevel="Info" writeTo="efcore" />
    <logger name="Microsoft.EntityFramework.*" minLevel="Trace" writeTo="efcore-diagnostics" />

    <logger name="System.*" finalMinLevel="Warn" />
    <logger name="Microsoft.*" finalMinLevel="Warn" />
    <logger name="Microsoft.Hosting.Lifetime*" finalMinLevel="Info" writeTo="lifetimeConsole" />
    <logger name="Microsoft.AspNetCore.Routing.*" finalMinLevel="Info" writeTo="lifetimeConsole" />
    <logger name="Microsoft.AspNetCore.Hosting.Diagnostics*" minLevel="Trace" writeTo="aspnet-diagnostics" />

    <logger name="*" minLevel="Trace" writeTo="ownFile-web" />
  </rules>
</nlog>