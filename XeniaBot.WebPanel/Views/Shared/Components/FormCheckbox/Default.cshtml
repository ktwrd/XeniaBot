@using XeniaBot.WebPanel.Models
@model FormCheckboxViewModel


<div class="@Model.CalculatedClasses">
    @if (string.IsNullOrEmpty(Model.ParentFormId))
    {
        <input class="form-check-input" type="checkbox" value="true" id="@Model.Id" name="@Model.Name" checked="@Model.State" />
    }
    else
    {
        <input class="form-check-input" type="checkbox" value="true" id="@Model.Id" name="@Model.Name" checked="@Model.State" form="@Model.ParentFormId" />
    }
    <label class="form-check-label" for="@Model.Id">
        @Model.Label
    </label>
</div>

