@model GuildBannerViewModel


@if (Model.Parameters.EnableBreadcrumb)
{
    <div role="enable-breadcrumb">
        <div class="d-flex flex-row align-items-center p-3 text-white rounded shadow-sm bg-body-secondary guildBanner">
            <img class="me-3 rounded-circle" src="@(Model.Guild.IconUrl)" alt="" width="48" height="48">
            <div class="lh-1">
                <h1 class="h6 mb-0 text-white lh-1">@Model.Guild.Name</h1>
                <small>@Model.Guild.MemberCount members</small>
            </div>
        </div>
        <nav style="--bs-breadcrumb-divider: '/';" aria-label="breadcrumb">
            <ol class="breadcrumb rounded shadow-sm bg-body-secondary px-3 pb-3">
                @foreach (var (index, item) in @Model.Parameters.Breadcrumbs.Index())
                {
                    var isLast = index == @Model.Parameters.Breadcrumbs.Count - 1;
                    var itemClass = "breadcrumb-item";
                    if (isLast) itemClass += " active";
                    <li class="@itemClass" @{
                        if (isLast)
                        {
                            <text>aria-current="page"</text>
                        }
                    }>
                        @if (item.Href != null)
                        {
                            <a href="@item.Href">@item.Name</a>
                        }
                        else if (item.TargetController != null && item.TargetAction != null)
                        {
                            if (item.TargetRoute == null)
                            {
                                <a asp-controller="@item.TargetController"
                                   asp-action="@item.TargetAction">
                                    @item.Name
                                </a>
                            }
                            else
                            {
                                <a asp-controller="@item.TargetController"
                                   asp-action="@item.TargetAction"
                                   asp-all-route-data="@item.TargetRoute">
                                    @item.Name
                                </a>
                            }
                        }
                        else
                        {
                            <span class="text-light">@item.Name</span>
                        }
                    </li>
                }
            </ol>
        </nav>
    </div>
}
else
{
    <div class="d-flex flex-row align-items-center p-3 rounded shadow-sm bg-body-secondary guildBanner">
        <img class="me-3 rounded-circle" src="@(Model.Guild.IconUrl)" alt="" width="48" height="48">
        <div class="lh-1">
            <h1 class="h6 mb-0 lh-1">@Model.Guild.Name</h1>
            <small>@Model.Guild.MemberCount members</small>
        </div>
    </div>
}